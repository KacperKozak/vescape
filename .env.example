EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=
EXPO_PUBLIC_MAPY_API_KEY=
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Vescape backend (../vescape-server) — one server behind every networked feature.
# Unset → prod (https://vescape.app). For a local server (`bun dev` in
# ../vescape-server) point here and run `bun run relay:reverse` once so the
# device's localhost:3000 tunnels to your machine over USB.
# EXPO_PUBLIC_SERVER_URL=http://localhost:3000

# Agent/debug-only PostHog API access. Keep real values in .env.local.
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://us.posthog.com
