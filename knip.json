{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": ["-lintignore"],
  "ignoreBinaries": ["maestro", "adb", "awk"],
  "ignoreDependencies": ["sharp"],
  "ignore": ["scripts/**/*", ".agents/**/*", ".claude/**/*", "app.config.ts"],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {
      "entry": ["plugins/**/*"]
    },
    "modules/*": {}
  }
}
