{
  "name": "vibe-wheel",
  "version": "0.33.0",
  "private": true,
  "workspaces": [
    "modules/*"
  ],
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "format": "oxfmt . '!.agents/skills/**'",
    "format:check": "oxfmt --check . '!.agents/skills/**'",
    "test": "bun run test:bun && bun run test:android",
    "test:bun": "bun test",
    "test:android": "cd android && ./gradlew :vesc-ble:testDebugUnitTest",
    "ts": "tsc --noEmit",
    "build:release": "cd android && ./gradlew assembleRelease",
    "release": "bun run scripts/release.ts",
    "release:fix": "bun run scripts/release.ts --patch"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.18",
    "@react-navigation/native": "^7.1.33",
    "@rnmapbox/maps": "^10.3.0",
    "expo": "^55.0.24",
    "expo-build-properties": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.34",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.18",
    "phosphor-react-native": "^3.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-pager-view": "8.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.4",
    "vesc-ble": "workspace:*",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "bun-types": "1.3.14",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.1",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.50.0",
    "typescript": "~5.9.2"
  }
}
