{
  "name": "vibe-wheel",
  "version": "0.45.0",
  "private": true,
  "workspaces": [
    "modules/*"
  ],
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "REACT_NATIVE_PACKAGER_HOSTNAME=localhost expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "format": "oxfmt . '!.agents/skills/**'",
    "format:check": "oxfmt --check . '!.agents/skills/**'",
    "copy:alert-sounds": "bun run scripts/copy-alert-sounds.ts",
    "test": "bun run test:bun && bun run test:android",
    "test:bun": "bun test",
    "test:android": "cd android && ./gradlew :vesc-ble:testDebugUnitTest",
    "ts": "tsc --noEmit",
    "build:release": "cd android && ./gradlew assembleRelease",
    "release": "bun run scripts/release.ts",
    "release:fix": "bun run scripts/release.ts --patch",
    "knip": "knip",
    "posthog:recent": "bun run scripts/posthog.ts recent",
    "posthog:events": "bun run scripts/posthog.ts events",
    "posthog:distinct": "bun run scripts/posthog.ts distinct",
    "posthog:query": "bun run scripts/posthog.ts query"
  },
  "dependencies": {
    "@rnmapbox/maps": "^10.3.0",
    "expo": "56.0.3",
    "expo-build-properties": "~56.0.13",
    "expo-constants": "~56.0.14",
    "expo-dev-client": "~56.0.14",
    "expo-document-picker": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-linking": "~56.0.11",
    "expo-router": "~56.2.5",
    "expo-sharing": "~56.0.13",
    "expo-splash-screen": "~56.0.9",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "phosphor-react-native": "^3.0.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.1",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.8.3",
    "vesc-ble": "workspace:*",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "~19.2.14",
    "bun-types": "1.3.14",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~56.0.4",
    "knip": "^6.14.1",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.50.0",
    "typescript": "^6.0.3"
  }
}
