{
  "name": "vibe-wheel",
  "version": "0.65.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "author": "Kacper Kozak",
  "workspaces": [
    "modules/*"
  ],
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "prebuild": "expo prebuild",
    "android": "bun run copy:shared && export NODE_BINARY=$(command -v node); export PATH=$(dirname \"$NODE_BINARY\"):$PATH; REACT_NATIVE_PACKAGER_HOSTNAME=localhost expo run:android",
    "android:e2e": "EXPO_PUBLIC_E2E=1 bun run android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "format": "oxfmt . '!.agents/skills/**'",
    "format:check": "oxfmt --check . '!.agents/skills/**'",
    "clear": "bun run scripts/clear.ts",
    "copy:shared": "bun run scripts/copy-shared.ts",
    "skills-check": "bun run scripts/skills-check.ts",
    "screenshot": "bun run scripts/screenshot.ts",
    "e2e": "bun run scripts/e2e.ts",
    "perf": "bun run scripts/perf-telemetry.ts",
    "test": "bun run copy:shared && bun run test:bun && bun run test:android",
    "test:bun": "bun test",
    "test:android": "export NODE_BINARY=$(command -v node); export PATH=$(dirname \"$NODE_BINARY\"):$PATH; cd android && ./gradlew :vesc-ble:testDebugUnitTest",
    "ts": "tsc --noEmit",
    "build:release": "bun run copy:shared && export NODE_BINARY=$(command -v node); export PATH=$(dirname \"$NODE_BINARY\"):$PATH; cd android && ./gradlew assembleRelease",
    "release": "bun run scripts/release.ts",
    "release:fix": "bun run scripts/release.ts --patch",
    "check": "bun run ts && bun run lint && bun run format:check && bun run knip && bun run test",
    "knip": "knip",
    "posthog:recent": "bun run scripts/posthog.ts recent",
    "posthog:events": "bun run scripts/posthog.ts events",
    "posthog:distinct": "bun run scripts/posthog.ts distinct",
    "posthog:query": "bun run scripts/posthog.ts query"
  },
  "dependencies": {
    "@rnmapbox/maps": "^10.3.0",
    "@shopify/react-native-skia": "2.6.2",
    "expo": "56.0.3",
    "expo-build-properties": "~56.0.13",
    "expo-constants": "~56.0.14",
    "expo-dev-client": "~56.0.14",
    "expo-document-picker": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-image": "^56.0.10",
    "expo-linking": "~56.0.11",
    "expo-media-library": "^56.0.6",
    "expo-router": "~56.2.5",
    "expo-sensors": "~56.0.5",
    "expo-sharing": "~56.0.13",
    "expo-splash-screen": "~56.0.9",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "^56.0.19",
    "expo-video": "^56.1.2",
    "phosphor-react-native": "^3.0.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.1",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.8.3",
    "vesc-ble": "workspace:*",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "~19.2.14",
    "bun-types": "1.3.14",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~56.0.4",
    "knip": "^6.14.1",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.50.0",
    "sharp": "^0.35.2",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "@shopify/react-native-skia"
  ]
}
